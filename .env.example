# --- Supabase ---
# Trouvables dans Supabase > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Clé secrète (jamais exposée au navigateur) - Project Settings > API > service_role
SUPABASE_SERVICE_ROLE_KEY=

# --- Stripe ---
# Trouvables dans Stripe > Developers > API keys (mode Test au départ)
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Généré après avoir créé le webhook (voir README étape 6)
STRIPE_WEBHOOK_SECRET=

# --- Site ---
# URL de votre site une fois déployé sur Vercel, ex: https://mon-site.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000
